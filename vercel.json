{
  "buildCommand": "cd atlas/dashboard/frontend && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "atlas/dashboard/frontend/dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
