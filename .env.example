ANTHROPIC_API_KEY=your_anthropic_api_key_here

# WDK microservice (Node.js — run: make wdk-service)
WDK_SERVICE_URL=http://localhost:3001
WDK_SERVICE_PORT=3001
WDK_SEED_PHRASE=                        # set to persist wallet across restarts
EVM_PROVIDER=https://eth.drpc.org       # mainnet default

# ── Devnet (Anvil local fork) ─────────────────────────────────────────────────
# 1. Run: make devnet       (starts Anvil forking mainnet on :8545)
# 2. Run: make wdk-service  (starts WDK service)
# 3. Run: make fund-wallet  (sends 50 USDT + 0.1 ETH to WDK wallet)
# 4. Set below, then: python3 main.py --demo
#
# EVM_PROVIDER=http://localhost:8545
# INITIAL_PORTFOLIO_USDT=50

# ── Portfolio ─────────────────────────────────────────────────────────────────
INITIAL_PORTFOLIO_USDT=100000

# ── Autonomous yield payout ───────────────────────────────────────────────────
YIELD_PAYOUT_ADDRESS=                   # beneficiary wallet address
YIELD_PAYOUT_THRESHOLD_USD=50           # USD threshold to trigger payout

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=5000

# ── Vercel + Railway deployment ───────────────────────────────────────────────
# Set VITE_API_URL in Vercel dashboard to your Railway backend URL, e.g.:
#   VITE_API_URL=https://atlas-api.up.railway.app
#
# Set in Railway atlas-api service:
#   ANTHROPIC_API_KEY=...
#   WDK_SERVICE_URL=https://atlas-wdk.up.railway.app
#   EVM_PROVIDER=http://localhost:8545  (or mainnet)
#   WDK_SEED_PHRASE=...                 (pin the wallet)
#   YIELD_PAYOUT_ADDRESS=...
